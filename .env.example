# ============================================================
# MESSAIAH — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# -----------------------------------------------------------
# Supabase (required)
# Get these from: https://app.supabase.com → Project Settings → API
# -----------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — ONLY needed for server-side scripts / enrichment workers.
# NEVER expose this in the browser or commit it publicly.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------
# Database (direct connection — for migrations / scripts only)
# Use session-mode pooler URL for compatibility with pgbouncer.
# -----------------------------------------------------------
# DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# -----------------------------------------------------------
# OAuth (configured inside Supabase dashboard)
# These are set in Supabase Auth → Providers, not in .env.
#
# Google OAuth:
#   Client ID     → Supabase dashboard
#   Client Secret → Supabase dashboard
#   Redirect URL  → https://your-project-ref.supabase.co/auth/v1/callback
# -----------------------------------------------------------

# -----------------------------------------------------------
# App Config (optional overrides)
# -----------------------------------------------------------
# VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------
# Enrichment Workers (optional — for self-hosted background jobs)
# -----------------------------------------------------------
# APOLLO_API_KEY=your-apollo-api-key
# OPENAI_API_KEY=your-openai-api-key
